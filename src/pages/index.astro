---
import "../styles/global.css";
import { isGitHubAuthConfigured } from "../auth";
import {
  appaloftLocaleCookieMaxAge,
  appaloftLocaleCookieName,
  appaloftLocales,
  getHomeCopy,
  localePath,
  normalizeAppaloftLocale,
  type AppaloftLocale,
} from "../lib/i18n";

type Props = {
  locale?: string;
};

const localeCookieDomain = (
  process.env.APPALOFT_LOCALE_COOKIE_DOMAIN ??
  process.env.PUBLIC_APPALOFT_LOCALE_COOKIE_DOMAIN ??
  ""
).trim();
const locale = normalizeAppaloftLocale(Astro.props.locale ?? Astro.cookies.get(appaloftLocaleCookieName)?.value);
const copy = getHomeCopy(locale);
const githubHref = "https://github.com/appaloft/appaloft";
const docsHref = "https://github.com/appaloft/appaloft/tree/main/docs";
const releasesHref = "https://github.com/appaloft/appaloft/releases";
const configuredConsoleHref = ((import.meta.env.PUBLIC_APPALOFT_CONSOLE_URL as string | undefined) ?? "").trim();
const consoleHref = configuredConsoleHref
  ? configuredConsoleHref.replace(/\/+$/, "") || "/"
  : "/deploy";
const canonicalHref = new URL(localePath(locale), Astro.url.origin).href;
const alternateHrefs = appaloftLocales.map((nextLocale) => ({
  href: new URL(localePath(nextLocale), Astro.url.origin).href,
  locale: nextLocale,
}));
const initialIdentity = Astro.locals.user?.name || Astro.locals.user?.email || null;
const initialAuthStatus = initialIdentity ? `${copy.auth.signedIn}: ${initialIdentity}` : copy.auth.signedOut;

Astro.cookies.set(appaloftLocaleCookieName, locale, {
  httpOnly: false,
  maxAge: appaloftLocaleCookieMaxAge,
  path: "/",
  sameSite: "lax",
  secure: Astro.url.protocol === "https:",
  ...(localeCookieDomain ? { domain: localeCookieDomain } : {}),
});

function localeLabel(nextLocale: AppaloftLocale) {
  return nextLocale === "zh-CN" ? "中文" : "EN";
}

type CodeToken = {
  text: string;
  className: string;
};

function highlightCliLine(line: string) {
  return line.split(/(\s+)/).map((text, index) => {
    if (/^\s+$/.test(text)) {
      return { text, className: "token-space" };
    }

    if (/^(https?:\/\/|[\w.-]+@|\d+\.\d+\.\d+\.\d+)/.test(text)) {
      return { text, className: "token-url" };
    }

    if (index === 0) {
      return { text, className: "token-command" };
    }

    if (text.startsWith("-")) {
      return { text, className: "token-flag" };
    }

    if (text === "|") {
      return { text, className: "token-operator" };
    }

    return { text, className: "token-plain" };
  });
}

function highlightWorkflowLine(line: string): CodeToken[] {
  const match = line.match(/^(\s*)(-\s*)?([^:#]+)(:\s*)(.*)$/);

  if (!match) {
    return [{ text: line, className: "token-plain" }];
  }

  const [, indent, dash = "", key, colon, value] = match;
  return [
    { text: indent, className: "token-space" },
    { text: dash, className: "token-operator" },
    { text: key, className: "token-key" },
    { text: colon, className: "token-punctuation" },
    { text: value, className: value.includes("${{") ? "token-secret" : "token-value" },
  ];
}

function highlightScenarioLine(line: string, badge: string) {
  return badge === "github" ? highlightWorkflowLine(line) : highlightCliLine(line);
}

function getScenarioIcon(key: string) {
  switch (key) {
    case "ai":
      return `
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 3.5 13.8 8.2 18.5 10 13.8 11.8 12 16.5 10.2 11.8 5.5 10 10.2 8.2 12 3.5Z" fill="currentColor"/>
          <path d="M18.3 14.4 19.2 16.8 21.6 17.7 19.2 18.6 18.3 21 17.4 18.6 15 17.7 17.4 16.8 18.3 14.4Z" fill="currentColor" opacity="0.78"/>
          <path d="M6.2 15.2 7 17.1 8.9 17.9 7 18.7 6.2 20.6 5.4 18.7 3.5 17.9 5.4 17.1 6.2 15.2Z" fill="currentColor" opacity="0.52"/>
        </svg>
      `;
    case "docker":
      return `
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="4.1" y="8" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <rect x="6.95" y="8" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <rect x="9.8" y="8" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <rect x="12.65" y="8" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <rect x="6.95" y="5.15" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <rect x="9.8" y="5.15" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <rect x="12.65" y="5.15" width="2.35" height="2.35" rx=".32" fill="currentColor"/>
          <path d="M3.45 11.55H16.3c.12 1.88-.38 3.34-1.5 4.39-1.12 1.04-2.68 1.56-4.69 1.56-2.1 0-3.77-.57-5-1.71-1.23-1.14-1.78-2.55-1.66-4.24Z" fill="currentColor"/>
          <path d="M16.05 11.95c.7-.55 1.53-.82 2.48-.82.65 0 1.15.1 1.47.31-.15 1.27-.66 2.22-1.52 2.84-.86.62-1.95.93-3.27.93" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      `;
    case "action":
      return `
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 3.1c-4.97 0-9 4.03-9 9 0 3.98 2.58 7.36 6.16 8.55.45.08.61-.2.61-.44 0-.22-.01-.93-.01-1.69-2.5.54-3.03-1.06-3.03-1.06-.4-1.03-.99-1.3-.99-1.3-.81-.56.06-.55.06-.55.9.06 1.38.92 1.38.92.8 1.37 2.1.98 2.61.75.08-.58.31-.98.56-1.2-2-.23-4.11-1-4.11-4.46 0-.98.35-1.78.92-2.41-.09-.23-.4-1.17.09-2.44 0 0 .75-.24 2.47.92a8.6 8.6 0 0 1 4.5 0c1.71-1.16 2.46-.92 2.46-.92.49 1.27.18 2.21.09 2.44.57.63.92 1.43.92 2.41 0 3.47-2.11 4.23-4.12 4.45.32.28.6.82.6 1.66 0 1.2-.01 2.16-.01 2.45 0 .24.16.52.62.43A9 9 0 0 0 21 12.1c0-4.97-4.03-9-9-9Z" fill="currentColor"/>
        </svg>
      `;
    case "desktop":
      return `
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3.2" y="4.2" width="17.6" height="12.8" rx="2.2" stroke="currentColor" stroke-width="1.7"/>
          <path d="M3.8 8.25h16.4" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8.2 20h7.6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
          <circle cx="6.3" cy="6.2" r=".8" fill="currentColor"/>
          <circle cx="8.9" cy="6.2" r=".8" fill="currentColor" opacity=".74"/>
          <circle cx="11.5" cy="6.2" r=".8" fill="currentColor" opacity=".48"/>
        </svg>
      `;
    case "cloud":
      return `
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M8.8 18.5h8.25a4.45 4.45 0 0 0 .22-8.9 5.8 5.8 0 0 0-11.12 1.8A3.75 3.75 0 0 0 8.8 18.5Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="m12 8.2 2.55 2.55M12 8.2l-2.55 2.55M12 8.2V15.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      `;
    default:
      return "";
  }
}
---

<!doctype html>
<html lang={locale} data-locale={locale} data-locale-cookie-domain={localeCookieDomain || undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={copy.meta.description} />
    <meta name="theme-color" content="#18213B" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalHref} />
    {alternateHrefs.map(({ href, locale: nextLocale }) => (
      <link rel="alternate" hreflang={nextLocale} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternateHrefs[0].href} />
    <title>{copy.meta.title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">{copy.skipLink}</a>
    <div class="site-shell">
      <header class="hero">
        <div class="hero-background" aria-hidden="true"></div>
        <nav class="nav" aria-label={copy.nav.label}>
          <a class="brand" href={localePath(locale)} aria-label={copy.nav.home}>
            <img
              class="brand-logo"
              src="/appaloft-logo-horizontal.svg"
              alt="Appaloft"
              width="188"
              height="54"
            />
          </a>
          <div class="nav-links">
            <a href="#examples">{copy.nav.platform}</a>
          </div>
          <button
            class="nav-menu-toggle"
            type="button"
            aria-label={copy.nav.menu}
            aria-controls="nav-menu"
            aria-expanded="false"
            data-nav-menu-toggle
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
          <div
            id="nav-menu"
            class="nav-actions"
            data-auth-widget
            data-nav-menu
            data-auth-locale={locale}
            data-auth-github-configured={isGitHubAuthConfigured ? "true" : "false"}
            data-auth-connect-github={copy.auth.connectGithub}
            data-auth-connecting={copy.auth.connecting}
            data-auth-connected={copy.auth.connected}
            data-auth-signed-in={copy.auth.signedIn}
            data-auth-signed-out={copy.auth.signedOut}
            data-auth-unavailable={copy.auth.unavailable}
          >
            <div class="locale-switcher" aria-label={copy.language.label}>
              {appaloftLocales.map((nextLocale) => (
                <a
                  class={nextLocale === locale ? "locale-link is-active" : "locale-link"}
                  href={localePath(nextLocale)}
                  data-locale-link={nextLocale}
                  aria-current={nextLocale === locale ? "page" : undefined}
                >
                  {localeLabel(nextLocale)}
                </a>
              ))}
            </div>
            <span class="auth-status" data-auth-status hidden={!isGitHubAuthConfigured && !initialIdentity}>
              {initialAuthStatus}
            </span>
            <button class="nav-cta auth-connect" type="button" data-auth-connect hidden={!isGitHubAuthConfigured}>
              {copy.auth.connectGithub}
            </button>
            <a class="nav-cta" href={consoleHref}>{copy.nav.console}</a>
          </div>
        </nav>

        <div class="hero-inner">
          <div class="hero-copy">
            <div class="hero-pronunciation" aria-label={copy.hero.pronunciation.label}>
              <span class="hero-pronunciation-name">{copy.hero.pronunciation.name}</span>
              <span class="hero-pronunciation-ipa">{copy.hero.pronunciation.ipa}</span>
              <span class="hero-pronunciation-read">
                <span>{copy.hero.pronunciation.app}</span>
                <span>{copy.hero.pronunciation.aloft}</span>
              </span>
            </div>
            <h1>{copy.hero.title}</h1>
            <div class="domain-demo" aria-label={copy.hero.domainDemo.label} data-domain-demo>
              <div class="domain-window">
                <div class="domain-chrome" aria-hidden="true">
                  <span></span><span></span><span></span>
                </div>
                <div class="domain-address" aria-hidden="true">
                  <span class="domain-security">
                    <span class="domain-lock"></span>
                  </span>
                  <span class="domain-url-stack">
                    <span class="domain-address-state is-local">
                      <span class="domain-url">{`http://${copy.hero.domainDemo.local}`}</span>
                    </span>
                    <span class="domain-address-state is-live">
                      <span class="domain-url">{`https://${copy.hero.domainDemo.live}`}</span>
                    </span>
                  </span>
                </div>
                <span class="sr-only">{copy.hero.domainDemo.screenReader}</span>
                <div class="domain-deploy-command" aria-hidden="true">
                  <div class="domain-terminal-input">
                    <span class="domain-command-prompt">$</span>
                    <span class="domain-command-text">
                      <strong>{copy.hero.domainDemo.deploy}</strong>
                    </span>
                    <span class="domain-command-cursor"></span>
                  </div>
                  <div class="domain-terminal-output">
                    {copy.hero.domainDemo.terminalLines.map((line, index) => (
                      <span class={index === 3 ? "domain-terminal-line line-4 is-typed" : `domain-terminal-line line-${index + 1}`}>
                        <span class="domain-terminal-status" aria-hidden="true">
                          <span class="status-loading"></span>
                          <span class="status-done">[ok]</span>
                        </span>
                        <span class="domain-terminal-text">{line}</span>
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
            <div class="hero-actions" aria-label={copy.hero.actionsLabel}>
              <a class="button button-primary" href="#examples">{copy.hero.primaryAction}</a>
              <a class="button button-secondary" href={releasesHref}>{copy.hero.secondaryAction}</a>
            </div>
          </div>

          <div class="hero-command-block">
            <p class="hero-command-kicker">{copy.hero.installLabel}</p>
            <div
              class="hero-command"
              aria-label={copy.hero.installLabel}
              data-command-shell
              data-copy-ready={copy.hero.copyCommand}
              data-copy-done={copy.hero.copiedCommand}
            >
              <div class="command-tabs" role="tablist" aria-label={copy.hero.installLabel}>
                {copy.hero.installOptions.map((option, index) => (
                  <button
                    class={index === 0 ? "command-tab is-active" : "command-tab"}
                    type="button"
                    role="tab"
                    aria-selected={index === 0 ? "true" : "false"}
                    data-install-tab={option.key}
                  >
                    {option.label}
                  </button>
                ))}
              </div>
              {copy.hero.installOptions.map((option, index) => (
                <div class={index === 0 ? "command-panel is-active" : "command-panel"} data-install-panel={option.key}>
                  <div class="command-panel-copy">
                    <strong>{option.title}</strong>
                    <p>{option.note}</p>
                  </div>
                  <div class="command-row">
                    <code data-command-value data-copy-value={option.command}>
                      {highlightCliLine(option.command).map((token) => (
                        <span class={`code-token ${token.className}`}>{token.text}</span>
                      ))}
                    </code>
                    <button class="command-copy" type="button" data-copy-command>{copy.hero.copyCommand}</button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </header>

      <main id="main">
        <section id="examples" class="section scenario-section">
          <div class="wrap">
            <div class="compact-heading">
              <p class="kicker">{copy.scenarios.kicker}</p>
              <h2>{copy.scenarios.title}</h2>
              <p>{copy.scenarios.body}</p>
            </div>

            <div class="scenario-list" aria-label={copy.scenarios.label}>
              {copy.scenarios.items.map((scenario, index) => (
                <article class={index % 2 === 1 ? "scenario-card is-reversed" : "scenario-card"}>
                  <div class="scenario-copy">
                    <div class="scenario-header">
                      <span class={`scenario-icon scenario-icon-${scenario.key}`} aria-hidden="true" set:html={getScenarioIcon(scenario.key)}></span>
                      <div class="scenario-heading-group">
                        <span class="scenario-label">{scenario.label}</span>
                        <span class="scenario-badge">{scenario.badge}</span>
                      </div>
                    </div>
                    <h3>{scenario.title}</h3>
                    <p>{scenario.body}</p>
                    <ul class="scenario-points">
                      {scenario.points.map((point) => (
                        <li>{point}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="scenario-visual">
                    {scenario.kind === "code" && scenario.lines && (
                      <div class={`terminal terminal-${scenario.badge}`}>
                        <div class="terminal-bar" aria-hidden="true"><span></span><span></span><span></span></div>
                        <pre><code>{scenario.lines.map((line) => (
                          <span class="terminal-line">{highlightScenarioLine(line, scenario.badge).map((token) => (
                            <span class={`code-token ${token.className}`}>{token.text}</span>
                          ))}</span>
                        ))}</code></pre>
                      </div>
                    )}

                    {scenario.kind === "image" && scenario.imageSrc && scenario.imageAlt && (
                      <figure class={`scenario-shot scenario-shot-${scenario.key}`}>
                        <img
                          src={scenario.imageSrc}
                          alt={scenario.imageAlt}
                          width={scenario.key === "ai" ? "1728" : "1536"}
                          height={scenario.key === "ai" ? "910" : "1024"}
                          loading="lazy"
                          decoding="async"
                        />
                      </figure>
                    )}

                    {scenario.kind === "cloud" && scenario.metrics && (
                      <div class="cloud-mock">
                        {scenario.metrics.map(([name, value]) => (
                          <div class="cloud-tile">
                            <span class="cloud-tile-icon" aria-hidden="true" set:html={getScenarioIcon("cloud")}></span>
                            <span>{name}</span>
                            <strong>{value}</strong>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

      </main>

      <footer class="footer">
        <div class="wrap footer-inner">
          <span>{copy.footer.text}</span>
          <div class="footer-links">
            <a href={githubHref}>{copy.nav.github}</a>
            <a href={docsHref}>{copy.footer.docs}</a>
          </div>
        </div>
      </footer>
    </div>

    <script>
      import "../scripts/page-actions";
    </script>
  </body>
</html>
