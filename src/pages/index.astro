---
import "../styles/global.css";
import { isGitHubAuthConfigured } from "../auth";
import {
  appaloftLocaleCookieMaxAge,
  appaloftLocaleCookieName,
  appaloftLocales,
  getHomeCopy,
  localePath,
  normalizeAppaloftLocale,
  type AppaloftLocale,
} from "../lib/i18n";

type Props = {
  locale?: string;
};

const localeCookieDomain = (
  process.env.APPALOFT_LOCALE_COOKIE_DOMAIN ??
  process.env.PUBLIC_APPALOFT_LOCALE_COOKIE_DOMAIN ??
  ""
).trim();
const locale = normalizeAppaloftLocale(Astro.props.locale ?? Astro.cookies.get(appaloftLocaleCookieName)?.value);
const copy = getHomeCopy(locale);
const githubHref = "https://github.com/appaloft/appaloft";
const docsHref = "https://github.com/appaloft/appaloft/tree/main/docs";
const releasesHref = "https://github.com/appaloft/appaloft/releases";
const configuredConsoleHref = ((import.meta.env.PUBLIC_APPALOFT_CONSOLE_URL as string | undefined) ?? "").trim();
const consoleHref = configuredConsoleHref
  ? configuredConsoleHref.replace(/\/+$/, "") || "/"
  : "/deploy";
const initialIdentity = Astro.locals.user?.name || Astro.locals.user?.email || null;
const initialAuthStatus = initialIdentity ? `${copy.auth.signedIn}: ${initialIdentity}` : copy.auth.signedOut;
const installCommandParts = copy.hero.installCommand.split(" ");
const installCommandStart = installCommandParts.slice(0, 2).join(" ");
const installCommandUrl = installCommandParts[2] ?? "";
const installCommandEnd = installCommandParts.slice(3).join(" ");

Astro.cookies.set(appaloftLocaleCookieName, locale, {
  httpOnly: false,
  maxAge: appaloftLocaleCookieMaxAge,
  path: "/",
  sameSite: "lax",
  secure: Astro.url.protocol === "https:",
  ...(localeCookieDomain ? { domain: localeCookieDomain } : {}),
});

function localeLabel(nextLocale: AppaloftLocale) {
  return nextLocale === "zh-CN" ? copy.language.simplifiedChinese : copy.language.english;
}

type CodeToken = {
  text: string;
  className: string;
};

function highlightCliLine(line: string) {
  return line.split(/(\s+)/).map((text, index) => {
    if (/^\s+$/.test(text)) {
      return { text, className: "token-space" };
    }

    if (index === 0) {
      return { text, className: "token-command" };
    }

    if (text.startsWith("-")) {
      return { text, className: "token-flag" };
    }

    if (text === "|") {
      return { text, className: "token-operator" };
    }

    if (/^(https?:\/\/|[\w.-]+@|\d+\.\d+\.\d+\.\d+)/.test(text)) {
      return { text, className: "token-url" };
    }

    return { text, className: "token-plain" };
  });
}

function highlightWorkflowLine(line: string): CodeToken[] {
  const match = line.match(/^(\s*)(-\s*)?([^:#]+)(:\s*)(.*)$/);

  if (!match) {
    return [{ text: line, className: "token-plain" }];
  }

  const [, indent, dash = "", key, colon, value] = match;
  return [
    { text: indent, className: "token-space" },
    { text: dash, className: "token-operator" },
    { text: key, className: "token-key" },
    { text: colon, className: "token-punctuation" },
    { text: value, className: value.includes("${{") ? "token-secret" : "token-value" },
  ];
}

function highlightScenarioLine(line: string, badge: string) {
  return badge === "workflow" ? highlightWorkflowLine(line) : highlightCliLine(line);
}
---

<!doctype html>
<html lang={locale} data-locale={locale} data-locale-cookie-domain={localeCookieDomain || undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={copy.meta.description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {appaloftLocales.map((nextLocale) => (
      <link rel="alternate" hreflang={nextLocale} href={localePath(nextLocale)} />
    ))}
    <title>{copy.meta.title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">{copy.skipLink}</a>
    <div class="site-shell">
      <header class="hero">
        <img class="hero-background" src="/images/appaloft-hero-cloud.jpg" alt="" aria-hidden="true" />
        <nav class="nav" aria-label={copy.nav.label}>
          <a class="brand" href={localePath(locale)} aria-label={copy.nav.home}>
            <span class="brand-mark" aria-hidden="true">A</span>
            <span>Appaloft</span>
          </a>
          <div class="nav-links">
            <a href="#entries">{copy.nav.platform}</a>
            <a href="#examples">{copy.nav.loop}</a>
          </div>
          <div
            class="nav-actions"
            data-auth-widget
            data-auth-locale={locale}
            data-auth-github-configured={isGitHubAuthConfigured ? "true" : "false"}
            data-auth-connect-github={copy.auth.connectGithub}
            data-auth-connecting={copy.auth.connecting}
            data-auth-connected={copy.auth.connected}
            data-auth-signed-in={copy.auth.signedIn}
            data-auth-signed-out={copy.auth.signedOut}
            data-auth-unavailable={copy.auth.unavailable}
          >
            <div class="locale-switcher" aria-label={copy.language.label}>
              {appaloftLocales.map((nextLocale) => (
                <a
                  class={nextLocale === locale ? "locale-link is-active" : "locale-link"}
                  href={localePath(nextLocale)}
                  data-locale-link={nextLocale}
                  aria-current={nextLocale === locale ? "page" : undefined}
                >
                  {localeLabel(nextLocale)}
                </a>
              ))}
            </div>
            <span class="auth-status" data-auth-status hidden={!isGitHubAuthConfigured && !initialIdentity}>
              {initialAuthStatus}
            </span>
            <button class="nav-cta auth-connect" type="button" data-auth-connect hidden={!isGitHubAuthConfigured}>
              {copy.auth.connectGithub}
            </button>
            <a class="nav-cta" href={consoleHref}>{copy.nav.console}</a>
          </div>
        </nav>

        <div class="hero-inner">
          <div class="hero-copy">
            <div class="hero-pronunciation" aria-label={copy.hero.pronunciation.label}>
              <span class="hero-pronunciation-name">{copy.hero.pronunciation.name}</span>
              <span class="hero-pronunciation-ipa">{copy.hero.pronunciation.ipa}</span>
              <span class="hero-pronunciation-read">
                <span>{copy.hero.pronunciation.app}</span>
                <span>{copy.hero.pronunciation.aloft}</span>
              </span>
            </div>
            <h1>{copy.hero.title}</h1>
            <div class="domain-demo" aria-label={copy.hero.domainDemo.label} data-domain-demo>
              <div class="domain-window">
                <div class="domain-chrome" aria-hidden="true">
                  <span></span><span></span><span></span>
                </div>
                <div class="domain-address" aria-hidden="true">
                  <span class="domain-security">
                    <span class="domain-lock"></span>
                  </span>
                  <span class="domain-url-stack">
                    <span class="domain-address-state is-local">
                      <span class="domain-url">{`http://${copy.hero.domainDemo.local}`}</span>
                    </span>
                    <span class="domain-address-state is-live">
                      <span class="domain-url">{`https://${copy.hero.domainDemo.live}`}</span>
                    </span>
                  </span>
                </div>
                <span class="sr-only">{copy.hero.domainDemo.screenReader}</span>
                <div class="domain-deploy-command" aria-hidden="true">
                  <div class="domain-terminal-input">
                    <span class="domain-command-prompt">$</span>
                    <span class="domain-command-text">
                      <strong>{copy.hero.domainDemo.deploy}</strong>
                    </span>
                    <span class="domain-command-cursor"></span>
                  </div>
                  <div class="domain-terminal-output">
                    {copy.hero.domainDemo.terminalLines.map((line, index) => (
                      <span class={index === 3 ? "domain-terminal-line line-4 is-typed" : `domain-terminal-line line-${index + 1}`}>
                        <span class="domain-terminal-status" aria-hidden="true">
                          <span class="status-loading"></span>
                          <span class="status-done">[ok]</span>
                        </span>
                        <span class="domain-terminal-text">{line}</span>
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
            <div class="hero-actions" aria-label={copy.hero.actionsLabel}>
              <a class="button button-primary" href="#examples">{copy.hero.primaryAction}</a>
              <a class="button button-secondary" href={releasesHref}>{copy.hero.secondaryAction}</a>
            </div>
          </div>

          <div
            class="hero-command"
            aria-label={copy.hero.installLabel}
            data-command-shell
            data-copy-ready={copy.hero.copyCommand}
            data-copy-done={copy.hero.copiedCommand}
          >
            <div class="command-head">
              <span>{copy.hero.installLabel}</span>
              <button class="command-copy" type="button" data-copy-command>{copy.hero.copyCommand}</button>
            </div>
            <div class="command-row">
              <code data-command-value data-copy-value={copy.hero.installCommand}>
                <span>{installCommandStart}</span>
                <span class="command-url">{installCommandUrl}</span>
                <span>{installCommandEnd}</span>
              </code>
            </div>
            <p>{copy.hero.installNote}</p>
          </div>
        </div>
      </header>

      <main id="main">
        <section id="examples" class="section scenario-section">
          <div class="wrap">
            <div class="compact-heading">
              <p class="kicker">{copy.scenarios.kicker}</p>
              <h2>{copy.scenarios.title}</h2>
              <p>{copy.scenarios.body}</p>
            </div>

            <div class="scenario-carousel" aria-label={copy.scenarios.label} data-scenario-carousel>
              <div class="scenario-tabs" role="tablist">
                {copy.scenarios.items.map((scenario, index) => (
                  <button
                    class={index === 0 ? "scenario-tab is-active" : "scenario-tab"}
                    type="button"
                    role="tab"
                    aria-selected={index === 0 ? "true" : "false"}
                    data-scenario-tab={String(index)}
                  >
                    <span>{scenario.label}</span>
                    <span class="scenario-progress" aria-hidden="true"></span>
                  </button>
                ))}
              </div>

              <div class="scenario-stage">
                {copy.scenarios.items.map((scenario, index) => (
                  <article
                    class={index === 0 ? "scenario-panel is-active" : "scenario-panel"}
                    data-scenario-panel={String(index)}
                    aria-hidden={index === 0 ? "false" : "true"}
                  >
                    <div class="scenario-copy">
                      <span class="scenario-badge">{scenario.badge}</span>
                      <h3>{scenario.title}</h3>
                      <p>{scenario.body}</p>
                    </div>

                    <div class="scenario-visual">
                      {scenario.kind === "code" && (
                        <div class={`terminal terminal-${scenario.badge}`}>
                          <div class="terminal-bar" aria-hidden="true"><span></span><span></span><span></span></div>
                          <pre><code>{scenario.lines.map((line) => (
                            <span class="terminal-line">{highlightScenarioLine(line, scenario.badge).map((token) => (
                              <span class={`code-token ${token.className}`}>{token.text}</span>
                            ))}</span>
                          ))}</code></pre>
                        </div>
                      )}

                      {scenario.kind === "desktop" && (
                        <div class="desktop-mock">
                          <div class="mock-sidebar">
                            <span>Appaloft</span>
                            <small>Servers</small>
                            <small>Apps</small>
                            <small>Deploys</small>
                          </div>
                          <div class="mock-main">
                            {scenario.cards.map(([name, status, meta]) => (
                              <div class="mock-row">
                                <strong>{name}</strong>
                                <span>{status}</span>
                                <small>{meta}</small>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}

                      {scenario.kind === "chat" && (
                        <div class="chat-mock">
                          {scenario.messages.map(([speaker, message]) => (
                            <div class={speaker === "you" ? "chat-line is-user" : "chat-line"}>
                              <small>{speaker}</small>
                              <span>{message}</span>
                            </div>
                          ))}
                        </div>
                      )}

                      {scenario.kind === "cloud" && (
                        <div class="cloud-mock">
                          {scenario.metrics.map(([name, value]) => (
                            <div class="cloud-tile">
                              <span>{name}</span>
                              <strong>{value}</strong>
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="entries" class="section section-soft">
          <div class="wrap feature-slab">
            <div>
              <p class="kicker">{copy.features.kicker}</p>
              <h2>{copy.features.title}</h2>
              <p>{copy.features.body}</p>
            </div>
            <div class="feature-list">
              {copy.features.items.map(([title, body]) => (
                <article>
                  <h3>{title}</h3>
                  <p>{body}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="section cta">
          <div class="wrap cta-inner">
            <div>
              <p class="kicker">{copy.cta.kicker}</p>
              <h2>{copy.cta.title}</h2>
              <p>{copy.cta.body}</p>
            </div>
            <div class="hero-actions">
              <a class="button button-primary" href={docsHref}>{copy.cta.docs}</a>
              <a class="button button-secondary" href={githubHref}>{copy.cta.github}</a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="wrap footer-inner">
          <span>{copy.footer.text}</span>
          <div class="footer-links">
            <a href={githubHref}>{copy.nav.github}</a>
            <a href={docsHref}>{copy.footer.docs}</a>
          </div>
        </div>
      </footer>
    </div>

    <script>
      import "../scripts/auth-widget";
      import "../scripts/home-actions";
    </script>
  </body>
</html>
